{
  "name": "parity-samples/phpunit",
  "description": "Runnable PHPUnit sample for Parity.",
  "type": "project",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0 || ^12.0"
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml"
  }
}
